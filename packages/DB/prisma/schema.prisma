generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  name     String
  email    String    @unique
  password String
  monitors Monitor[]
}

model Monitor {
  id               String         @id @default(uuid())
  userid           String
  url              String
  interval         Int            @default(60)
  createdAt        DateTime       @default(now())
  status           MonitorStatus  @default(UP)
  sslExpiryDays    Int?
  port             Int?
  type             ConnectionType @default(HTTP)
  maintenanceEnd   String?
  maintenanceStart String?
  slug             String?        @unique
  title            String?
  active           Boolean        @default(true)
  checks           Check[]
  user             User           @relation(fields: [userid], references: [id])
  @@index([userid])
}

model Check {
  id        String    @id @default(uuid())
  monitorId String
  status    Int
  latency   Int
  ok        Boolean
  checkedAt DateTime  @default(now())
  monitor   Monitor   @relation(fields: [monitorId], references: [id])
  incident  Incident?

  @@index([monitorId, checkedAt(sort: Desc)])
}

model Incident {
  id              String  @id @default(uuid())
  checkId         String  @unique
  dns             String?
  sslDays         Int?
  pingLatency     Float?
  hops            Json?
  rawError        String?
  failureHop      String?
  failureLocation String?
  check           Check   @relation(fields: [checkId], references: [id])

  @@index([checkId])
}

enum MonitorStatus {
  UP
  PENDING
  DOWN
}

enum ConnectionType {
  HTTP
  PORT
}
